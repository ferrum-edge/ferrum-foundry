{
  "name": "ferrum-foundry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,server -c blue,green \"vite\" \"tsx watch server/index.ts\"",
    "dev:vite": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "build:vite": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "lint": "eslint src server --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-router": "^1.120.6",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.6",
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^9.1.0",
    "jose": "^6.0.11",
    "ky": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "undici": "^8.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.5",
    "@tailwindcss/vite": "^4.1.5",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vite": "^6.3.3"
  }
}
